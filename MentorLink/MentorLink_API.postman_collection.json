      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token_mentee}}" }],
        "body": { "mode": "raw", "raw": "{\n  \"mentor_id\": {{mentor_id}},\n  \"scheduled_at\": \"2026-06-10 09:00:00\",\n  \"duration_min\": 60\n}", "options": { "raw": { "language": "json" } } },
        "url": "{{base_url}}/sessions"
      }
    },
