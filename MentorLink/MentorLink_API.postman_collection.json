{
  "info": {
    "name": "MentorLink API",
    "description": "Collection séquentielle — un seul Run exécute tout dans l'ordre. IMPORTANT: avant de lancer, mettre le rôle admin manuellement: UPDATE users SET role='admin' WHERE email='admin_test@mentorlink.com'",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",        "value": "http://localhost:8000/api" },
    { "key": "token_mentee",    "value": "" },
    { "key": "token_mentor",    "value": "" },
    { "key": "token_admin",     "value": "" },
    { "key": "mentor_id",       "value": "" },
    { "key": "mentee_id",       "value": "" },
    { "key": "session_id",      "value": "" },
    { "key": "availability_id", "value": "" },
    { "key": "report_id",       "value": "" }
  ],
  "item": [
    {
      "name": "01 - Inscription Mentor",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "var json = pm.response.json();",
          "pm.test('[01] Inscription Mentor - Status 201', () => pm.response.to.have.status(201));",
          "if (json.token) {",
          "  pm.collectionVariables.set('token_mentor', json.token);",
          "  pm.collectionVariables.set('mentor_id', json.user.id);",
          "}"
        ]}
      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Marie Mentor\",\n  \"email\": \"mentor_test@mentorlink.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"role\": \"mentor\"\n}", "options": { "raw": { "language": "json" } } },
        "url": "{{base_url}}/register"
      }
    },
    {
      "name": "02 - Inscription Mentee",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "var json = pm.response.json();",
          "pm.test('[02] Inscription Mentee - Status 201', () => pm.response.to.have.status(201));",
          "if (json.token) {",
          "  pm.collectionVariables.set('token_mentee', json.token);",
          "  pm.collectionVariables.set('mentee_id', json.user.id);",
          "}"
        ]}
      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jean Mentoré\",\n  \"email\": \"mentee_test@mentorlink.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"role\": \"mentee\"\n}", "options": { "raw": { "language": "json" } } },
        "url": "{{base_url}}/register"
      }
    },
    {
      "name": "03 - Inscription Admin",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "var json = pm.response.json();",
          "pm.test('[03] Inscription Admin - Status 201', () => pm.response.to.have.status(201));",
          "pm.test('[03] NOTE: Changer role admin en BDD avant de continuer les tests admin', () => pm.expect(true).to.be.true);"
        ]}
      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Admin MentorLink\",\n  \"email\": \"admin_test@mentorlink.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"role\": \"mentee\"\n}", "options": { "raw": { "language": "json" } } },
        "url": "{{base_url}}/register"
      }
    },
    {
      "name": "04 - Connexion Admin (après UPDATE role en BDD)",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "var json = pm.response.json();",
          "pm.test('[04] Connexion Admin - Status 200', () => pm.response.to.have.status(200));",
          "if (json.token) { pm.collectionVariables.set('token_admin', json.token); }"
        ]}
      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin_test@mentorlink.com\",\n  \"password\": \"password123\"\n}", "options": { "raw": { "language": "json" } } },
        "url": "{{base_url}}/login"
      }
    },
    {
      "name": "05 - Connexion Mentor",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "var json = pm.response.json();",
          "pm.test('[05] Connexion Mentor - Status 200', () => pm.response.to.have.status(200));",
          "if (json.token) {",
          "  pm.collectionVariables.set('token_mentor', json.token);",
          "  pm.collectionVariables.set('mentor_id', json.user.id);",
          "}"
        ]}
      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"mentor_test@mentorlink.com\",\n  \"password\": \"password123\"\n}", "options": { "raw": { "language": "json" } } },
        "url": "{{base_url}}/login"
      }
    },
    {
      "name": "06 - Connexion Mentee",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "var json = pm.response.json();",
          "pm.test('[06] Connexion Mentee - Status 200', () => pm.response.to.have.status(200));",
          "if (json.token) { pm.collectionVariables.set('token_mentee', json.token); }"
        ]}
      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"mentee_test@mentorlink.com\",\n  \"password\": \"password123\"\n}", "options": { "raw": { "language": "json" } } },
        "url": "{{base_url}}/login"
      }
    },
    {
      "name": "07 - GET /me (mentor connecté)",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('[07] GET /me - Status 200', () => pm.response.to.have.status(200));",
          "pm.test('[07] Email correct', () => pm.expect(pm.response.json().email).to.eql('mentor_test@mentorlink.com'));"
        ]}
      }],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token_mentor}}" }],
        "url": "{{base_url}}/me"
      }
    },
    {
      "name": "08 - Créer profil mentor",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('[08] Créer profil mentor - Status 200', () => pm.response.to.have.status(200));",
          "pm.test('[08] Domaines présents', () => pm.expect(pm.response.json().domains).to.be.an('array'));"
        ]}
      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token_mentor}}" }],
        "body": { "mode": "raw", "raw": "{\n  \"domains\": [\"Algorithmique\", \"Laravel\", \"Bases de données\"],\n  \"hourly_rate\": 2500,\n  \"bio\": \"Master 2 Informatique, passionné par le dev web.\"\n}", "options": { "raw": { "language": "json" } } },
        "url": "{{base_url}}/mentor/profile"
      }
    },
    {
      "name": "09 - [Admin] Valider profil mentor",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('[09] Valider profil - Status 200', () => pm.response.to.have.status(200));",
          "pm.test('[09] is_validated = true', () => pm.expect(pm.response.json().profile.is_validated).to.be.true);"
        ]}
      }],
      "request": {
        "method": "PUT",
        "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token_admin}}" }],
        "url": "{{base_url}}/admin/mentors/{{mentor_id}}/validate"
      }
    },
    {
      "name": "10 - Liste mentors validés (doit contenir 1)",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('[10] Liste mentors - Status 200', () => pm.response.to.have.status(200));",
          "pm.test('[10] Au moins 1 mentor validé', () => pm.expect(pm.response.json().data.length).to.be.above(0));"
        ]}
      }],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": "{{base_url}}/mentors"
      }
    },
    {
      "name": "11 - Filtrer mentors par domaine",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('[11] Filtre domaine - Status 200', () => pm.response.to.have.status(200));"
        ]}
      }],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/mentors?domain=Laravel", "host": ["{{base_url}}"], "path": ["mentors"], "query": [{ "key": "domain", "value": "Laravel" }] }
      }
    },
    {
      "name": "12 - Ajouter créneau Lundi 09h-11h",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "var json = pm.response.json();",
          "pm.test('[12] Ajouter créneau - Status 201', () => pm.response.to.have.status(201));",
          "if (json.id) { pm.collectionVariables.set('availability_id', json.id); }"
        ]}
      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token_mentor}}" }],
        "body": { "mode": "raw", "raw": "{\n  \"day_of_week\": 1,\n  \"start_time\": \"09:00\",\n  \"end_time\": \"11:00\"\n}", "options": { "raw": { "language": "json" } } },
        "url": "{{base_url}}/availabilities"
      }
    },
    {
      "name": "13 - Modifier créneau",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('[13] Modifier créneau - Status 200', () => pm.response.to.have.status(200));"
