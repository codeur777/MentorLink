      "request": {
        "method": "PUT",
        "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token_mentor}}" }],
        "body": { "mode": "raw", "raw": "{\n  \"start_time\": \"09:00\",\n  \"end_time\": \"12:00\"\n}", "options": { "raw": { "language": "json" } } },
        "url": "{{base_url}}/availabilities/{{availability_id}}"
      }
    },
    {
      "name": "14 - Créneaux libres du mentor",
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('[14] Créneaux libres - Status 200', () => pm.response.to.have.status(200));",
          "pm.test('[14] Propriété slots présente', () => pm.expect(pm.response.json()).to.have.property('slots'));"
        ]}
      }],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token_mentee}}" }],
        "url": "{{base_url}}/mentors/{{mentor_id}}/availabilities"
      }
    },
    {
      "name": "15 - Réserver une session",
